APP_ENV=development
LOG_LEVEL=info
PORT=3000
DEFAULT_USER_ID=local-user
DEFAULT_TEMPERATURE=0.3

ENABLE_HTTP=true
ENABLE_TERMINAL=true
ENABLE_TELEGRAM=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_POLL_INTERVAL_MS=1500
TELEGRAM_LONG_POLL_TIMEOUT_SEC=30

DEFAULT_PROVIDER=local
FALLBACK_PROVIDER=local

OPENAI_API_KEY=
# OpenAI-compatible base URL (OpenAI, The Claw Bay, etc.)
OPENAI_BASE_URL=https://api.openai.com/v1
OPENROUTER_API_KEY=

DEFAULT_MODEL=jarvis-local
FAST_MODEL=jarvis-local-fast
REASONING_MODEL=jarvis-local-reasoning
EMBEDDING_MODEL=jarvis-local-embedding
FALLBACK_MODEL=jarvis-local

ENABLE_WEB_SEARCH=true
ALLOW_WEB_SEARCH_BY_DEFAULT=true
WEB_SEARCH_MAX_RESULTS=5

# Commands: /time, /sys time, /sys get-time, //time, //sys time - set true to enable
ENABLE_SYSTEM_COM=true

# When enabled, Jarvis may convert natural language into //tool commands.
ENABLE_TOOL_ROUTER=false
# tool-scaffold:insert:env

ENABLE_MEMORY=true
AUTO_STORE_MEMORY=true
MEMORY_RETRIEVAL_LIMIT=5
MEMORY_SUMMARY_TRIGGER_MESSAGES=8

# Set to memory to avoid Postgres.
PERSISTENCE_DRIVER=postgres
DATABASE_URL=postgresql://postgres:admin%40password@localhost:5432/jarvis
