# Jarvis environment variables
#
# Most product settings can live in jarvis.config.json.
# Environment variables are best for deployment, secrets, and host-specific overrides.
# Precedence: environment variables > jarvis.config.json > code defaults.

APP_ENV=development
LOG_LEVEL=info
PORT=3000
DEFAULT_USER_ID=local-user

# Allow a browser or external client origin to call the HTTP API.
# Leave unset unless you need CORS for a separate frontend or local client.
# HTTP_ALLOWED_ORIGIN=http://localhost:5173

# Security
# API_KEY=your-secret-key-here

# Rate limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=20

# Input validation
MAX_MESSAGE_LENGTH=10000

# LLM reliability
LLM_TIMEOUT_MS=60000
LLM_MAX_RETRIES=3

# Persistence
PERSISTENCE_DRIVER=memory
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/jarvis

# Optional: pgvector for embeddings (Postgres only)
ENABLE_PGVECTOR=false
PGVECTOR_DIMENSIONS=1536

# Memory backend
MEMORY_BACKEND=local
# ZEP_API_KEY=your-zep-api-key
ZEP_BASE_URL=https://api.getzep.com

# Tool toggles
ENABLE_MEMORY_LOOKUP=true
ENABLE_POWERSHELL=true
ENABLE_AUTOMATION=true
AUTOMATION_POLL_INTERVAL_MS=30000
AUTOMATION_MAX_DUE_PER_TICK=5
# tool-scaffold:insert:env
