# Jarvis — Environment Variables
#
# Most settings now live in jarvis.config.json (created by the setup wizard).
# Run `npm run setup` to create or reconfigure it.
#
# This .env file is for infrastructure/deployment settings only.
# Values here override jarvis.config.json when set.

APP_ENV=development
LOG_LEVEL=info
PORT=3000
DEFAULT_USER_ID=local-user
WEB_APP_ORIGIN=http://localhost:5173

# Persistence
PERSISTENCE_DRIVER=memory
# DATABASE_URL=postgresql://postgres:YOUR_PASSWORD@localhost:5432/jarvis

# Optional: pgvector for embeddings (Postgres only)
ENABLE_PGVECTOR=false
PGVECTOR_DIMENSIONS=1536
# tool-scaffold:insert:env
